{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://etymolt.com/docs/verdict-protocol/evp-1.schema.json",
  "title": "Etymolt Verdict Protocol Verdict Object",
  "type": "object",
  "required": [
    "evp_version",
    "name",
    "verdict",
    "score",
    "axes",
    "verdict_id",
    "issued_at",
    "disclaimer",
    "signature",
    "signature_key_id",
    "signature_payload_digest",
    "status"
  ],
  "properties": {
    "evp_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "verdict": {
      "type": "string",
      "enum": [
        "PROCEED",
        "PROCEED_STRATEGIC",
        "ABANDON"
      ]
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "axes": {
      "type": "object",
      "required": [
        "trademark",
        "domain",
        "cultural",
        "sound_symbolism",
        "pronunciation"
      ],
      "properties": {
        "trademark": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            {
              "type": "object",
              "description": "Full per-axis envelope (v1.1+ structured form)."
            }
          ]
        },
        "domain": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            {
              "type": "object",
              "description": "Full per-axis envelope (v1.1+ structured form)."
            }
          ]
        },
        "cultural": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            {
              "type": "object",
              "description": "Full per-axis envelope (v1.1+ structured form)."
            }
          ]
        },
        "sound_symbolism": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            {
              "type": "object",
              "description": "Full per-axis envelope (v1.1+ structured form)."
            }
          ]
        },
        "pronunciation": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            {
              "type": "object",
              "description": "Full per-axis envelope (v1.1+ structured form)."
            }
          ]
        }
      },
      "additionalProperties": false,
      "description": "Per-axis verdict map. v1.0: each axis MAY be either (a) a flat integer 0-100 score (terse form, default API surface) or (b) an object with status/score/findings/evidence_of_record/coverage_caveat (structured form, recommended for verdicts that downstream agents will reason over). The 5 canonical axes are trademark, domain, cultural, sound_symbolism, pronunciation."
    },
    "verdict_id": {
      "type": "string",
      "pattern": "^v_[A-Za-z0-9_-]{12,}$"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "disclaimer": {
      "type": "string",
      "minLength": 1
    },
    "signature": {
      "type": "string",
      "contentEncoding": "base64"
    },
    "signature_key_id": {
      "type": "string",
      "minLength": 1
    },
    "signature_payload_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "signature_co": {
      "type": "object",
      "required": [
        "signature",
        "signature_key_id",
        "signature_payload_digest"
      ],
      "properties": {
        "signature": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "signature_key_id": {
          "type": "string",
          "minLength": 1
        },
        "signature_payload_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "one_line": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "confidence_interval": {
      "type": "object",
      "properties": {
        "lower": {
          "type": "number"
        },
        "upper": {
          "type": "number"
        },
        "point_estimate": {
          "type": "number"
        },
        "method": {
          "type": "string"
        }
      }
    },
    "permalink": {
      "type": "string",
      "format": "uri"
    },
    "jurisdictions_consulted": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "complete",
        "partial"
      ],
      "description": "Engine signal-sufficiency state. 'partial' indicates engine had insufficient signal; the verdict is the best estimate and the consumer should treat it as advisory."
    },
    "reason": {
      "type": "string",
      "enum": [
        "clean",
        "famous_mark",
        "high_collision",
        "no_distinctiveness",
        "descriptive",
        "insufficient_corpus"
      ],
      "description": "Stable closed-set sub-code explaining the verdict."
    },
    "verdict_legacy": {
      "type": "string",
      "enum": [
        "PROCEED",
        "DUE_DILIGENCE",
        "ITERATE",
        "ABANDON",
        "INSUFFICIENT_SIGNAL"
      ],
      "description": "Engine's pre-2026-06-10 5-state internal verdict. OPTIONAL. Issuers MAY surface this for back-compat with consumers built before the 3-value cutover."
    }
  },
  "patternProperties": {
    "^x_": {}
  },
  "additionalProperties": true,
  "$defs": {
    "axis_status": {
      "type": "string",
      "enum": [
        "CLEAR",
        "CAUTION",
        "BLOCKED",
        "INSUFFICIENT_SIGNAL",
        "UNKNOWN"
      ]
    }
  }
}
